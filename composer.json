{
    "name": "plmrlnsnts/typewriter",
    "description": "A tool for generating PHP code based on a GraphQL schema and GraphQL operations.",
    "license": "MIT",
    "type": "library",
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "Plmrlnsnts\\Typewriter\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Plmrlnsnts\\Typewriter\\Tests\\": "tests/",
            "Plmrlnsnts\\TypewriterApp\\": "tests/generated/"
        }
    },
    "authors": [
        {
            "name": "Paul Santos",
            "email": "paulmarlonsantos@gmail.com"
        }
    ],
    "bin": [
        "typewriter"
    ],
    "require-dev": {
        "phpunit/phpunit": "^12.5.12",
        "spatie/phpunit-snapshot-assertions": "^5.3",
        "laravel/pint": "^1.29"
    },
    "require": {
        "php": "^8.3",
        "nette/php-generator": "^4.2",
        "webonyx/graphql-php": "^15.30"
    }
}
